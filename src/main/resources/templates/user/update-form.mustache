{{> layout/header}}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- 마이페이지 프로필 카드 -->
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                <div class="card-body p-4 text-center">
                    <div class="mb-3">
                        <i class="fas fa-user-circle fa-5x text-secondary"></i>
                    </div>
                    <h3 style="font-weight: 700;">마이페이지</h3>
                    <p class="text-muted">{{userDetail.username}} ({{userDetail.email}})</p>
                    <span class="badge bg-light text-dark p-2" style="border-radius: 8px;">일반 회원</span>
                </div>
            </div>

            <!-- 회원 정보 조회 및 수정 섹션 -->
            <div class="card shadow-sm border-0 mb-4" style="border-radius: 15px;">
                <div class="card-body p-5">
                    <h5 class="mb-4" style="font-weight: 600;"><i class="fas fa-info-circle me-2"></i>상세 정보</h5>
                    <form action="/user/update" method="post">
                        <div class="mb-3">
                            <label class="form-label text-muted small">아이디</label>
                            <input type="text" class="form-control bg-light" value="{{userDetail.username}}" readonly>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small">비밀번호 (변경 시에만 입력)</label>
                            <input type="password" class="form-control" name="password" placeholder="새 비밀번호를 입력하세요">
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small">이메일</label>
                            <input type="email" class="form-control" name="email" value="{{userDetail.email}}" required>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label text-muted small">우편번호</label>
                                <input type="text" class="form-control" name="postcode" value="{{userDetail.postcode}}">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small">주소</label>
                            <input type="text" class="form-control" name="address" value="{{userDetail.address}}">
                        </div>
                        <div class="mb-3">
                            <label class="form-label text-muted small">상세주소 1</label>
                            <input type="text" class="form-control" name="detailAddress" value="{{userDetail.detailAddress}}">
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-muted small">상세주소 2</label>
                            <input type="text" class="form-control" name="extraAddress" value="{{userDetail.extraAddress}}">
                        </div>
                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary" style="border-radius: 10px;">정보 수정 완료</button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- 위험 구역 (회원 탈퇴) -->
            <div class="card shadow-sm border-0 border-top border-danger border-4" style="border-radius: 15px;">
                <div class="card-body p-4">
                    <h5 class="text-danger mb-3" style="font-weight: 600;"><i class="fas fa-exclamation-triangle me-2"></i>위험 구역</h5>
                    <p class="text-muted small mb-4">회원을 탈퇴하면 작성하신 모든 게시글과 댓글이 삭제되며 복구할 수 없습니다.</p>
                    <form action="/user/withdraw" method="post" onsubmit="return confirm('정말로 탈퇴하시겠습니까? 관련 데이터가 모두 삭제됩니다.')">
                        <div class="d-grid">
                            <button type="submit" class="btn btn-danger" style="border-radius: 10px;">회원 탈퇴하기</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}
